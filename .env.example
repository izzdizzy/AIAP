# Python Environment Variables Template
# Copy this file to .env and fill in your API keys

# OpenAI API Key (for LLM-powered Care Navigation)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Alternative: Anthropic API Key (if using Claude)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Note: The Gen AI assistant will work without API keys using rule-based fallback.
# Set the API key only if you want LLM-powered recommendations.
