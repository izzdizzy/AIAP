# Python Environment Variables Template
# Copy this file to .env and fill in your API keys

# Groq API Key (for LLM-powered Care Navigation)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Alternative: Google AI API Key (if using Gemini models)
# GOOGLE_API_KEY=your_google_api_key_here

# Alternative: OpenAI API Key (if using GPT models)
# OPENAI_API_KEY=your_openai_api_key_here

# Note: The Gen AI assistant will work without API keys using rule-based fallback.
# Set the API key only if you want LLM-powered recommendations.
